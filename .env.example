# ============================
# DramaBuzz Environment Config
# ============================

NODE_ENV=development
PORT=3000

# MongoDB URI
MONGODB_URI=mongodb://localhost:27017/dramabuzz

# JWT Secrets (thay bằng chuỗi ngẫu nhiên dài)
JWT_SECRET=your_jwt_secret_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Admin mặc định (khi seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_DISPLAY_NAME=Quản trị viên

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
