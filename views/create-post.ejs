<%
  const isEdit     = typeof editPost !== 'undefined' && editPost;
  const pageTitle  = isEdit ? 'Sửa bài viết' : 'Đăng bài mới';
  const activePage = 'home';
%>
<%- include('partials/header') %>
<link rel="stylesheet" href="/css/post.css?v=2026.04.16.01">

<main class="container">
  <div class="page-layout">
    <%- include('partials/sidebar-left') %>

    <div class="main-content">
      <div class="feed-panel">
        <div class="cp-topbar">
          <a href="javascript:history.back()" class="cp-back-btn"><i class="fas fa-arrow-left"></i></a>
          <h1 class="cp-title"><i class="fas fa-feather-alt"></i> <%= isEdit ? 'Sửa bài viết' : 'Đăng bài mới' %></h1>
        </div>

        <div class="cp-card">
          <form id="postForm" enctype="multipart/form-data" data-edit-id="<%= isEdit ? editPost._id : '' %>">

            <!-- Title -->
            <div class="cp-field">
              <label class="cp-label">Tiêu đề <span class="cp-required">*</span></label>
              <input class="cp-input" type="text" name="title" required placeholder="Nhập tiêu đề bài viết..."
                value="<%= isEdit ? editPost.title : '' %>">
            </div>

            <!-- Excerpt -->
            <div class="cp-field">
              <label class="cp-label">Tóm tắt <span class="cp-required">*</span></label>
              <textarea class="cp-input cp-textarea" name="excerpt" rows="2" required placeholder="Mô tả ngắn về bài viết..."><%= isEdit ? editPost.excerpt : '' %></textarea>
            </div>

            <!-- Content -->
            <div class="cp-field">
              <label class="cp-label">Nội dung <span class="cp-required">*</span></label>
              <textarea class="cp-input cp-textarea cp-textarea--lg" name="content" rows="8" required placeholder="Viết nội dung bài viết của bạn..."><%- isEdit ? editPost.content : '' %></textarea>
            </div>

            <!-- Media section -->
            <div class="cp-media-section">
              <div class="cp-media-tabs">
                <button type="button" class="cp-media-tab cp-media-tab--active" data-tab="images">
                  <i class="fas fa-images"></i> Hình ảnh
                </button>
                <button type="button" class="cp-media-tab" data-tab="videos">
                  <i class="fas fa-video"></i> Video
                </button>
              </div>

              <!-- Images Tab -->
              <div class="cp-media-pane" id="cp-tab-images">
                <!-- Upload zone -->
                <div class="cp-upload-zone" id="imageDropZone">
                  <input type="file" name="images" id="imageFileInput" multiple accept="image/*" hidden>
                  <div class="cp-upload-zone-inner" id="imageZoneInner">
                    <i class="fas fa-cloud-upload-alt cp-upload-icon"></i>
                    <p class="cp-upload-text">Kéo thả ảnh vào đây hoặc <span class="cp-upload-link" id="imageChooseBtn">chọn từ máy</span></p>
                    <p class="cp-upload-hint">Hỗ trợ JPG, PNG, GIF, WEBP — Tối đa 9 ảnh, mỗi ảnh ≤ 50MB</p>
                  </div>
                  <div class="cp-preview-grid" id="imagePreviewGrid"></div>
                </div>

                <!-- Image URL input -->
                <div class="cp-url-row">
                  <input class="cp-input cp-url-input" type="url" id="imageUrlInput" placeholder="Hoặc dán URL ảnh trực tiếp...">
                  <button type="button" class="cp-url-add-btn" id="imageUrlAddBtn"><i class="fas fa-plus"></i> Thêm</button>
                </div>
                <div class="cp-url-chips" id="imageUrlChips"></div>
                <!-- Hidden inputs for imageUrls will be appended here by JS -->
                <div id="imageUrlHiddenInputs"></div>
              </div>

              <!-- Videos Tab -->
              <div class="cp-media-pane cp-media-pane--hidden" id="cp-tab-videos">
                <!-- Upload zone -->
                <div class="cp-upload-zone" id="videoDropZone">
                  <input type="file" name="videos" id="videoFileInput" multiple accept="video/mp4,video/webm,video/ogg,video/quicktime" hidden>
                  <div class="cp-upload-zone-inner" id="videoZoneInner">
                    <i class="fas fa-film cp-upload-icon"></i>
                    <p class="cp-upload-text">Kéo thả video vào đây hoặc <span class="cp-upload-link" id="videoChooseBtn">chọn từ máy</span></p>
                    <p class="cp-upload-hint">Hỗ trợ MP4, WEBM, OGG, MOV — Tối đa 3 video, mỗi video ≤ 50MB</p>
                  </div>
                  <div class="cp-preview-grid cp-preview-grid--video" id="videoPreviewGrid"></div>
                </div>

                <!-- Video URL (YouTube or direct) -->
                <div class="cp-url-row">
                  <input class="cp-input cp-url-input" type="url" id="videoUrlInput" placeholder="Hoặc dán URL YouTube / video trực tiếp...">
                  <button type="button" class="cp-url-add-btn" id="videoUrlAddBtn"><i class="fas fa-plus"></i> Thêm</button>
                </div>
                <div class="cp-url-chips" id="videoUrlChips"></div>
                <div id="videoUrlHiddenInputs"></div>
              </div>
            </div>

            <!-- Categories -->
            <div class="cp-field">
              <label class="cp-label">Danh mục</label>
              <div class="cp-checkbox-grid" id="catCheckboxes">
                <% if (typeof categories !== 'undefined') { %>
                  <% categories.forEach(function(cat) {
                    const checked = isEdit && editPost.categories && editPost.categories.some(c => String(c._id || c) === String(cat._id));
                  %>
                    <label class="cp-checkbox-label">
                      <input type="checkbox" name="categories[]" value="<%= cat._id %>" <%= checked ? 'checked' : '' %>>
                      <span><%= cat.icon %> <%= cat.name %></span>
                    </label>
                  <% }); %>
                <% } %>
              </div>
            </div>

            <!-- Tags -->
            <div class="cp-field">
              <label class="cp-label">Tags <span class="cp-hint-text">(phân cách bởi dấu phẩy)</span></label>
              <input class="cp-input" type="text" name="tags" placeholder="drama, hot, 2025..."
                value="<%= isEdit && editPost.tags ? editPost.tags.join(', ') : '' %>">
            </div>

            <!-- Keep existing images/videos in edit mode -->
            <% if (isEdit) { %>
              <% if (editPost.images && editPost.images.length) { %>
                <% editPost.images.forEach(function(img) { %>
                  <input type="hidden" name="keepImages[]" value="<%= img %>">
                <% }); %>
              <% } %>
              <% if (editPost.videos && editPost.videos.length) { %>
                <% editPost.videos.forEach(function(v) { %>
                  <input type="hidden" name="keepVideos[]" value="<%= v %>">
                <% }); %>
              <% } %>
            <% } %>

            <!-- Submit -->
            <div class="cp-actions">
              <button type="submit" class="cp-submit-btn" id="postSubmitBtn">
                <i class="fas fa-paper-plane"></i> <%= isEdit ? 'Lưu thay đổi' : 'Đăng bài' %>
              </button>
            </div>
            <p id="postFormMsg" class="form-helper-text" style="display:none"></p>

          </form>
        </div>
      </div>
    </div>

    <%- include('partials/sidebar-right', { hideCategories: true, sidebarClass: 'home-sidebar-right', hideProfile: true }) %>
  </div>
</main>

<footer class="site-footer">
  <div class="container">
    <p><strong>🔥 DramaBuzz</strong> – Blog giải trí & drama 24/7 · Đăng nhập để tương tác!</p>
  </div>
</footer>

<script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
<script src="/js/common.js"></script>
<script src="/js/index.js"></script>
<script>
(function () {
  /* ── Tab switching ───────────────────────── */
  document.querySelectorAll('.cp-media-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.cp-media-tab').forEach(t => t.classList.remove('cp-media-tab--active'));
      document.querySelectorAll('.cp-media-pane').forEach(p => p.classList.add('cp-media-pane--hidden'));
      tab.classList.add('cp-media-tab--active');
      document.getElementById('cp-tab-' + tab.dataset.tab).classList.remove('cp-media-pane--hidden');
    });
  });

  /* ── Image upload zone ───────────────────── */
  setupUploadZone({
    dropZone:    document.getElementById('imageDropZone'),
    fileInput:   document.getElementById('imageFileInput'),
    chooseBtn:   document.getElementById('imageChooseBtn'),
    zoneInner:   document.getElementById('imageZoneInner'),
    previewGrid: document.getElementById('imagePreviewGrid'),
    maxCount:    9,
    type:        'image',
  });

  /* ── Video upload zone ───────────────────── */
  setupUploadZone({
    dropZone:    document.getElementById('videoDropZone'),
    fileInput:   document.getElementById('videoFileInput'),
    chooseBtn:   document.getElementById('videoChooseBtn'),
    zoneInner:   document.getElementById('videoZoneInner'),
    previewGrid: document.getElementById('videoPreviewGrid'),
    maxCount:    3,
    type:        'video',
  });

  /* ── Generic upload zone setup ───────────── */
  function setupUploadZone({ dropZone, fileInput, chooseBtn, zoneInner, previewGrid, maxCount, type }) {
    let dt = new DataTransfer();

    chooseBtn.addEventListener('click', () => fileInput.click());

    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('cp-upload-zone--drag'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('cp-upload-zone--drag'));
    dropZone.addEventListener('drop', e => {
      e.preventDefault();
      dropZone.classList.remove('cp-upload-zone--drag');
      handleFiles(Array.from(e.dataTransfer.files));
    });

    fileInput.addEventListener('change', () => {
      handleFiles(Array.from(fileInput.files));
    });

    function handleFiles(newFiles) {
      const allowed = maxCount - dt.files.length;
      if (allowed <= 0) { showToast('Đã đạt giới hạn ' + maxCount + ' file', 'error'); return; }
      newFiles.slice(0, allowed).forEach(f => dt.items.add(f));
      fileInput.files = dt.files;
      renderPreviews();
    }

    function removeFile(index) {
      const newDt = new DataTransfer();
      Array.from(dt.files).forEach((f, j) => { if (j !== index) newDt.items.add(f); });
      dt = newDt;
      fileInput.files = dt.files;
      renderPreviews();
    }

    function renderPreviews() {
      previewGrid.innerHTML = '';
      if (dt.files.length === 0) { zoneInner.style.display = ''; return; }
      zoneInner.style.display = 'none';

      Array.from(dt.files).forEach((f, i) => {
        const item = document.createElement('div');
        item.className = 'cp-preview-item';

        if (type === 'image') {
          const img = document.createElement('img');
          img.className = 'cp-preview-img';
          img.src = URL.createObjectURL(f);
          item.appendChild(img);
        } else {
          const icon = document.createElement('div');
          icon.className = 'cp-preview-video-icon';
          icon.innerHTML = '<i class="fas fa-film"></i>';
          const name = document.createElement('span');
          name.className = 'cp-preview-video-name';
          name.textContent = f.name.length > 20 ? f.name.slice(0, 18) + '\u2026' : f.name;
          item.appendChild(icon);
          item.appendChild(name);
        }

        const del = document.createElement('button');
        del.type = 'button';
        del.className = 'cp-preview-del';
        del.innerHTML = '<i class="fas fa-times"></i>';
        del.addEventListener('click', () => removeFile(i));
        item.appendChild(del);
        previewGrid.appendChild(item);
      });

      if (dt.files.length < maxCount) {
        const addMore = document.createElement('div');
        addMore.className = 'cp-preview-addmore';
        addMore.innerHTML = '<i class="fas fa-plus"></i>';
        addMore.addEventListener('click', () => fileInput.click());
        previewGrid.appendChild(addMore);
      }
    }
  }

  /* ── URL chips ───────────────────────────── */
  setupUrlChips({
    inputEl:       document.getElementById('imageUrlInput'),
    addBtn:        document.getElementById('imageUrlAddBtn'),
    chipsEl:       document.getElementById('imageUrlChips'),
    hiddenInputsEl:document.getElementById('imageUrlHiddenInputs'),
    fieldName:     'imageUrls',
  });

  setupUrlChips({
    inputEl:       document.getElementById('videoUrlInput'),
    addBtn:        document.getElementById('videoUrlAddBtn'),
    chipsEl:       document.getElementById('videoUrlChips'),
    hiddenInputsEl:document.getElementById('videoUrlHiddenInputs'),
    fieldName:     'videoUrls',
  });

  function setupUrlChips({ inputEl, addBtn, chipsEl, hiddenInputsEl, fieldName }) {
    const urls = [];

    function addUrl() {
      const val = inputEl.value.trim();
      if (!val) return;
      try { new URL(val); } catch { showToast('URL không hợp lệ', 'error'); return; }
      if (urls.includes(val)) { showToast('URL đã được thêm', 'info'); return; }
      urls.push(val);
      inputEl.value = '';
      renderChips();
    }

    addBtn.addEventListener('click', addUrl);
    inputEl.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); addUrl(); } });

    function renderChips() {
      chipsEl.innerHTML = '';
      hiddenInputsEl.innerHTML = '';
      urls.forEach((url, i) => {
        const chip = document.createElement('div');
        chip.className = 'cp-url-chip';
        const label = document.createElement('span');
        label.className = 'cp-url-chip-label';
        label.textContent = url.length > 45 ? url.slice(0, 43) + '…' : url;
        label.title = url;
        const del = document.createElement('button');
        del.type = 'button';
        del.className = 'cp-url-chip-del';
        del.innerHTML = '&times;';
        del.addEventListener('click', () => { urls.splice(i, 1); renderChips(); });
        chip.appendChild(label);
        chip.appendChild(del);
        chipsEl.appendChild(chip);

        const hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = fieldName + '[]';
        hidden.value = url;
        hiddenInputsEl.appendChild(hidden);
      });
    }
  }
})();
</script>
</body>
</html>
