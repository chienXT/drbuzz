<%
  /* ── Classic Blog Post Detail ── */
  const _post     = typeof post     !== 'undefined' ? post     : {};
  const _comments = typeof comments !== 'undefined' ? comments : [];
  const _related  = typeof related  !== 'undefined' ? related  : [];
  const _recent   = typeof recentPosts !== 'undefined' ? recentPosts : [];
  const _cats     = typeof categories !== 'undefined' ? categories : [];
  const pageTitle = _post.title || 'Bài viết Classic';
  const metaDesc  = _post.excerpt || '';
  const ogType    = 'article';
  const ogImage   = _post.thumbnail || _post.images?.[0] || '';
%>
<%- include('partials/header') %>
<div class="classic-page">

  <div class="classic-container">
    <!-- Breadcrumb -->
    <nav class="classic-breadcrumb">
      <a href="/">Trang chủ</a>
      <span class="classic-breadcrumb__sep">/</span>
      <a href="/blog">Blog</a>
      <span class="classic-breadcrumb__sep">/</span>
      <% if (_post.categories && _post.categories.length) { %>
        <a href="/blog?category=<%= _post.categories[0]._id || _post.categories[0] %>"><%= _post.categories[0].name || 'Danh mục' %></a>
        <span class="classic-breadcrumb__sep">/</span>
      <% } %>
      <span><%= _post.title %></span>
    </nav>

    <div class="classic-layout">
      <!-- Main -->
      <main>
        <article class="classic-article">
          <div class="classic-article__header">
            <% if (_post.categories && _post.categories.length) { %>
              <div class="classic-post-card__cats" style="justify-content:center;margin-bottom:12px">
                <% _post.categories.forEach(function(cat) { %>
                  <a href="/blog?category=<%= cat._id || cat %>" class="classic-post-card__cat"><%= cat.name || '' %></a>
                <% }); %>
              </div>
            <% } %>
            <h1 class="classic-article__title"><%= _post.title %></h1>
            <div class="classic-article__meta">
              <span><i class="far fa-user"></i> <%= _post.author?.displayName || _post.author?.username || 'Ẩn danh' %></span>
              <span><i class="far fa-calendar-alt"></i> <%= new Date(_post.createdAt).toLocaleDateString('vi-VN') %></span>
              <span><i class="far fa-eye"></i> <%= _post.views || 0 %> lượt xem</span>
              <span><i class="far fa-comment"></i> <%= _comments.length || 0 %> bình luận</span>
              <span><i class="far fa-heart"></i> <%= _post.likes?.length || 0 %> thích</span>
            </div>
          </div>

          <% if (_post.thumbnail || (_post.images && _post.images.length)) { %>
            <img src="<%= _post.thumbnail || _post.images[0] %>" alt="<%= _post.title %>" class="classic-article__cover" loading="lazy">
          <% } %>

          <div class="classic-article__content">
            <%- _post.content %>
          </div>

          <% if (_post.tags && _post.tags.length) { %>
            <div class="classic-article__tags">
              <% _post.tags.forEach(function(tag) { %>
                <a href="/blog?tag=<%= encodeURIComponent(tag) %>" class="classic-article__tag">#<%= tag %></a>
              <% }); %>
            </div>
          <% } %>

          <div class="classic-article__stats">
            <span><i class="far fa-eye"></i> <%= _post.views || 0 %> lượt xem</span>
            <span><i class="far fa-heart"></i> <%= _post.likes?.length || 0 %> lượt thích</span>
            <% if (typeof user !== 'undefined' && user) { %>
              <button class="classic-btn classic-btn--ghost" id="classicLikeBtn"
                      data-post-id="<%= _post._id %>"
                      data-liked="<%= _post.likes?.map(String).includes(String(user._id)) ? '1' : '0' %>">
                <i class="<%= _post.likes?.map(String).includes(String(user._id)) ? 'fas' : 'far' %> fa-heart"></i>
                <span><%= _post.likes?.map(String).includes(String(user._id)) ? 'Đã thích' : 'Thích' %></span>
              </button>
              <button class="classic-btn classic-btn--ghost" id="classicBookmarkBtn"
                      data-post-id="<%= _post._id %>"
                      data-bookmarked="<%= _post.bookmarkBy?.map(String).includes(String(user._id)) ? '1' : '0' %>">
                <i class="<%= _post.bookmarkBy?.map(String).includes(String(user._id)) ? 'fas' : 'far' %> fa-bookmark"></i>
                <span><%= _post.bookmarkBy?.map(String).includes(String(user._id)) ? 'Đã lưu' : 'Lưu' %></span>
              </button>
            <% } %>
          </div>
        </article>

        <!-- Related posts -->
        <% if (_related.length) { %>
          <div style="margin-bottom:32px">
            <h2 class="classic-page-title" style="font-size:1.3rem;margin-bottom:20px">Bài viết liên quan</h2>
            <% _related.forEach(function(rp) { %>
              <article class="classic-post-card">
                <div class="classic-post-card__img-wrap" style="width:180px;min-height:120px">
                  <img src="<%= rp.thumbnail || rp.images?.[0] || '/images/default-avatar.svg' %>"
                       alt="" class="classic-post-card__img" loading="lazy">
                </div>
                <div class="classic-post-card__body">
                  <h3 class="classic-post-card__title" style="font-size:1rem">
                    <a href="/blog/<%= rp.slug || rp._id %>"><%= rp.title %></a>
                  </h3>
                  <p class="classic-post-card__excerpt"><%= rp.excerpt %></p>
                  <div class="classic-post-card__meta">
                    <span><i class="far fa-calendar-alt"></i> <%= new Date(rp.createdAt).toLocaleDateString('vi-VN') %></span>
                    <span><i class="far fa-eye"></i> <%= rp.views || 0 %></span>
                  </div>
                </div>
              </article>
            <% }); %>
          </div>
        <% } %>

        <!-- Comments -->
        <section class="classic-comments" id="comments">
          <h2 class="classic-comments__title">
            <i class="far fa-comments"></i> Bình luận (<%= _comments.length || 0 %>)
          </h2>

          <% if (typeof user !== 'undefined' && user) { %>
            <div class="classic-comment-form">
              <form id="classicCommentForm" data-post-id="<%= _post._id %>">
                <textarea name="text" placeholder="Viết bình luận của bạn..." required minlength="1" maxlength="2000"></textarea>
                <div class="classic-comment-form__actions">
                  <button type="submit" class="classic-btn"><i class="fas fa-paper-plane"></i> Gửi bình luận</button>
                </div>
              </form>
            </div>
          <% } else { %>
            <p style="color:var(--cl-ink-3);font-size:.9rem;margin-bottom:16px">
              <a href="/?login=1" style="color:var(--cl-accent)">Đăng nhập</a> để bình luận.
            </p>
          <% } %>

          <div id="classicCommentList">
            <%
              const topComments = _comments.filter(c => !c.parent);
              const replies     = _comments.filter(c => c.parent);
            %>
            <% topComments.forEach(function(cmt) { %>
              <div class="classic-comment" data-id="<%= cmt._id %>">
                <img src="<%= cmt.author?.avatar || '/images/default-avatar.svg' %>" alt="" class="classic-comment__avatar">
                <div class="classic-comment__body">
                  <div class="classic-comment__header">
                    <span class="classic-comment__name"><%= cmt.author?.displayName || cmt.author?.username || 'Ẩn danh' %></span>
                    <span class="classic-comment__date"><%= new Date(cmt.createdAt).toLocaleDateString('vi-VN') %></span>
                  </div>
                  <div class="classic-comment__text"><%= cmt.text %></div>

                  <%/* replies */
                    const childReplies = replies.filter(r => String(r.parent) === String(cmt._id) || String(r.parent?._id) === String(cmt._id));
                  %>
                  <% childReplies.forEach(function(rep) { %>
                    <div class="classic-comment" style="margin-top:12px;padding-left:0;border:none">
                      <img src="<%= rep.author?.avatar || '/images/default-avatar.svg' %>" alt="" class="classic-comment__avatar" style="width:32px;height:32px">
                      <div class="classic-comment__body">
                        <div class="classic-comment__header">
                          <span class="classic-comment__name"><%= rep.author?.displayName || rep.author?.username || 'Ẩn danh' %></span>
                          <span class="classic-comment__date"><%= new Date(rep.createdAt).toLocaleDateString('vi-VN') %></span>
                        </div>
                        <div class="classic-comment__text"><%= rep.text %></div>
                      </div>
                    </div>
                  <% }); %>
                </div>
              </div>
            <% }); %>
          </div>
        </section>
      </main>

      <!-- Sidebar -->
      <aside class="classic-sidebar">
        <!-- Author info -->
        <% if (_post.author) { %>
          <div class="classic-sidebar__block" style="text-align:center">
            <img src="<%= _post.author.avatar || '/images/default-avatar.svg' %>"
                 alt="" style="width:64px;height:64px;border-radius:50%;object-fit:cover;margin-bottom:10px">
            <div style="font-weight:600;font-size:.95rem"><%= _post.author.displayName || _post.author.username %></div>
            <% if (_post.author.bio) { %>
              <p style="font-size:.82rem;color:var(--cl-ink-3);margin-top:6px"><%= _post.author.bio %></p>
            <% } %>
            <a href="/u/<%= _post.author.username %>" class="classic-btn classic-btn--ghost" style="margin-top:12px;font-size:.82rem">
              <i class="fas fa-user"></i> Xem trang cá nhân
            </a>
          </div>
        <% } %>

        <!-- Categories -->
        <div class="classic-sidebar__block">
          <div class="classic-sidebar__title">Danh mục</div>
          <ul class="classic-sidebar__cat-list">
            <% _cats.forEach(function(cat) { %>
              <li class="classic-sidebar__cat-item">
                <a href="/blog?category=<%= cat._id %>" class="classic-sidebar__cat-link"><%= cat.name %></a>
              </li>
            <% }); %>
          </ul>
        </div>

        <!-- Recent -->
        <% if (_recent.length) { %>
          <div class="classic-sidebar__block">
            <div class="classic-sidebar__title">Bài viết gần đây</div>
            <ul class="classic-sidebar__recent">
              <% _recent.slice(0, 5).forEach(function(rp) { %>
                <li class="classic-sidebar__recent-item">
                  <a href="/blog/<%= rp.slug || rp._id %>" class="classic-sidebar__recent-link"><%= rp.title %></a>
                  <div class="classic-sidebar__recent-date"><%= new Date(rp.createdAt).toLocaleDateString('vi-VN') %></div>
                </li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <div class="classic-sidebar__block" style="text-align:center">
          <a href="/blog" class="classic-btn classic-btn--ghost"><i class="fas fa-arrow-left"></i> Về Blog</a>
        </div>
      </aside>
    </div>
  </div>

  <!-- Footer -->
  <footer class="classic-footer">
    <div class="classic-footer__inner">
      <div class="classic-footer__copy">&copy; <%= new Date().getFullYear() %> <span style="background: linear-gradient(135deg, #dc2626, #f97316); -webkit-background-clip: text; background-clip: text; color: transparent; font-weight: 800;">DramaBuzz</span>. All rights reserved.</div>
      <div class="classic-footer__social">
        <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
        <a href="#" title="YouTube"><i class="fab fa-youtube"></i></a>
        <a href="#" title="Instagram"><i class="fab fa-instagram"></i></a>
      </div>
    </div>
  </footer>
</div>

<script>
  window.__POST_ID__ = '<%= _post._id %>';
</script>
<script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
<script src="/js/common.js?v=2026.04.16.23"></script>
<script src="/js/classic.js?v=2025.06.01"></script>
</body>
</html>
